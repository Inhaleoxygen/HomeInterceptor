# Gradle
.gradle/
**/build/
!**/src/**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignoring Gradle wrapper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
.project
.classpath

# Android Studio / IntelliJ
.idea/
*.iml

# Local Android config
local.properties

# OS junk
.DS_Store
Thumbs.db
